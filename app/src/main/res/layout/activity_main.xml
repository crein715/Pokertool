<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/surface">

    <ImageView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/ic_spade"
        android:layout_marginBottom="8dp"
        android:contentDescription="icon" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PokerTool"
        android:textSize="30sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI покер-помічник для ClubGG"
        android:textSize="14sp"
        android:textColor="@color/on_surface_dim"
        android:layout_marginBottom="36dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● Зупинено"
        android:textSize="18sp"
        android:textColor="@color/fold_red"
        android:layout_marginBottom="28dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/btn_primary_bg"
            android:text="СТАРТ"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/edit_text_bg"
            android:text="СТОП"
            android:textColor="@color/on_surface_dim"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnSettings"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/edit_text_bg"
        android:text="⚙  Налаштування"
        android:textColor="@color/on_surface_dim"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginTop="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:text="Як користуватись:\n1. Введіть OpenAI API ключ в Налаштуваннях\n2. Натисніть СТАРТ і дайте дозволи\n3. Відкрийте ClubGG\n4. Натисніть кнопку ♠ для аналізу"
        android:textColor="@color/on_surface_dim"
        android:textSize="13sp"
        android:lineSpacingExtra="4dp" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/result_overlay_bg"
    android:padding="20dp"
    android:layout_margin="16dp"
    android:elevation="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/actionText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RAISE"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/raise_green" />

        <TextView
            android:id="@+id/confidenceText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HIGH"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/confidence_high"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp" />

        <TextView
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="✕"
            android:textColor="@color/on_surface_dim"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/cardsText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="8♠ K♥"
            android:textSize="16sp"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/stageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RIVER"
            android:textSize="12sp"
            android:textColor="@color/on_surface_dim" />
    </LinearLayout>

    <TextView
        android:id="@+id/handNameText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Two pair, Kings and Eights"
        android:textSize="14sp"
        android:textColor="@color/call_yellow"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/reasoningText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You have a strong two pair..."
        android:textSize="13sp"
        android:textColor="@color/on_surface_dim"
        android:lineSpacingExtra="3dp" />

    <TextView
        android:id="@+id/extraInfoText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Pot: 2,900 | Stack: 12,000 | Pos: BTN"
        android:textSize="11sp"
        android:textColor="#55FFFFFF" />

</LinearLayout>

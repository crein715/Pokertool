<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/result_overlay_bg"
    android:padding="14dp"
    android:layout_marginHorizontal="10dp"
    android:elevation="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/actionText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="РЕЙЗ"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/raise_green" />

        <TextView
            android:id="@+id/equityText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="78%"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/btnClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="✕"
            android:textColor="@color/on_surface_dim"
            android:textSize="16sp"
            android:gravity="center" />
    </LinearLayout>

    <TextView
        android:id="@+id/cardsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="8♠ K♥ → Дві пари"
        android:textSize="15sp"
        android:textColor="@color/call_yellow"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/probsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:textColor="@color/on_surface_dim"
        android:fontFamily="monospace"
        android:lineSpacingExtra="2dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/mathText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#CCFFFFFF"
        android:lineSpacingExtra="2dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/infoText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:textColor="#88FFFFFF"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/playersText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="10sp"
        android:textColor="#77FFFFFF"
        android:fontFamily="monospace"
        android:maxLines="6"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/reasoningText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="@color/on_surface_dim"
        android:maxLines="8" />

</LinearLayout>

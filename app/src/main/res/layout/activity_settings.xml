<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@color/surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Налаштування"
        android:textSize="26sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:layout_marginBottom="28dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OpenAI API ключ"
        android:textSize="14sp"
        android:textColor="@color/on_surface_dim"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/apiKeyInput"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/edit_text_bg"
        android:hint="sk-..."
        android:textColorHint="#55FFFFFF"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        android:inputType="textPassword"
        android:singleLine="true"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Стиль гри"
        android:textSize="14sp"
        android:textColor="@color/on_surface_dim"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/playStyleSpinner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/edit_text_bg"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="20dp"
        android:entries="@array/play_styles" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI модель"
        android:textSize="14sp"
        android:textColor="@color/on_surface_dim"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/modelSpinner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/edit_text_bg"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="28dp" />

    <TextView
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/btn_primary_bg"
        android:text="ЗБЕРЕГТИ"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Отримати ключ:\nplatform.openai.com/api-keys\n\nВартість: ~$0.01-0.03 за аналіз"
        android:textColor="#77FFFFFF"
        android:textSize="12sp"
        android:lineSpacingExtra="4dp" />

</LinearLayout>
